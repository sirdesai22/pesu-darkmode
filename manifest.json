{
  "manifest_version": 3,
  "name": "PESU DARK MODE",
  "version": "1.1",
  "description": "Dark mode, motivational quotes & custom homepage for PESU Academy.",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["https://api.github.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PESU DARK MODE",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "and.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "homepage.html"
  }
}